# === SRE Framework config ===

# Prometheus API base URL
PROMETHEUS_URL=http://prometheus:9090

# Path to main SRE config. Mount your own file here to override services/provider
# without rebuilding the image.
SRE_CONFIG_FILE=app/config/sre.yaml

# === ops4life deployment only (Traefik + Authentik) ===
TRAEFIK_HOST=ops4life.com
COMPOSE_PROJECT_NAME=sre

# === Sentry Config ===
# Sentry DSN for backend error tracking & performance monitoring
SENTRY_DSN=
# Optional: Separate DSN for frontend. If not set, falls back to SENTRY_DSN.
SENTRY_FRONTEND_DSN=
# Traces sample rate (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=1.0

